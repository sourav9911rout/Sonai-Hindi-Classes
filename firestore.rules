rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'sourav.9911rout@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidDailyTasks(data) {
      return data.keys().hasAll(['date', 'questions', 'createdAt'])
          && data.keys().size() == 3
          && data.date is string
          && data.date.size() == 10
          && data.questions is list
          && data.questions.size() > 0;
    }

    // Daily Tasks collection
    match /dailyTasks/{date} {
      // Anyone can read the daily tasks
      allow get, list: if true;

      // Allow creation/update if admin OR if it matches schema (initial creation)
      allow create: if isValidDailyTasks(request.resource.data)
                    && date == request.resource.data.date;
      
      allow update: if isAdmin() && isValidDailyTasks(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
